{
  "name": "@mza1n/causality-context",
  "version": "2.0.1",
  "description": "Causality context (correlation/causation/execution) propagation for HTTP, WebSocket, NATS and Redis pub/sub",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nats": {
      "types": "./dist/nats.module.d.ts",
      "default": "./dist/nats.module.js"
    },
    "./tracing": {
      "types": "./dist/tracing.d.ts",
      "default": "./dist/tracing.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "default": "./dist/register.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mZa1n/causality-context.git"
  },
  "peerDependencies": {
    "@nestjs/common": "^11",
    "@opentelemetry/api": "^1.9.0",
    "express": "^5",
    "nats": "^2"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "nats": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "express": "^5.0.0",
    "nats": "^2.29.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/instrumentation": "^7.8.0",
    "uuidv7": "^1.2.1"
  }
}
